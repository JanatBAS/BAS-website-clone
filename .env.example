# Admin Panel Environment Variables
# All 3 are required for the admin panel to function.

# bcrypt hash of admin password
# Generate with: node -e "require('bcryptjs').hash('your-password',12).then(console.log)"
ADMIN_PASSWORD_HASH=

# Secret key for signing JWT tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Vercel Blob read/write token
# Auto-created when connecting a Blob store in the Vercel dashboard
BLOB_READ_WRITE_TOKEN=
